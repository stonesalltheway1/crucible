{
  "name": "@crucible/web-console",
  "version": "2026.06.0-phase7",
  "private": true,
  "description": "Crucible web console — evidence-driven engineering surface for senior engineers reviewing what the agent did to their codebase.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
