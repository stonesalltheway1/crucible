{
  "name": "@crucible/sdk",
  "version": "2026.6.0-phase1",
  "description": "Crucible Agent SDK — twin.* API surface for TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types src/**/*.test.ts"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "fast-check": "^4.0.0"
  }
}
