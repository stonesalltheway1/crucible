{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crucible.dev/MemoryWrite/v1",
  "title": "MemoryWrite",
  "type": "object",
  "required": ["convention_id", "tenant_id", "scope", "rule_nl", "category", "confidence", "writer_oidc_subject", "written_at"],
  "properties": {
    "convention_id":         { "type": "string" },
    "tenant_id":             { "type": "string" },
    "scope": {
      "type": "object",
      "properties": {
        "repo":      { "type": "string" },
        "file_glob": { "type": "string" },
        "category":  { "type": "string" }
      },
      "additionalProperties": false
    },
    "rule_nl":               { "type": "string", "minLength": 1 },
    "category":              { "type": "string" },
    "source_evidence": {
      "type": "array",
      "items": { "type": "object" }
    },
    "confidence":            { "type": "number", "minimum": 0, "maximum": 1 },
    "judge_score":           { "type": "number", "minimum": 0, "maximum": 1 },
    "writer_oidc_subject":   { "type": "string", "format": "uri" },
    "written_at":            { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
